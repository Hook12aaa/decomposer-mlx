# decomposer config — copy to .env and customize

# Model identifiers (HuggingFace repos)
DECOMPOSER_HF_REPO=Qwen/Qwen-Image-Layered
DECOMPOSER_TEXT_ENCODER_REPO=Qwen/Qwen2.5-VL-7B-Instruct
DECOMPOSER_GGUF_REPO=unsloth/Qwen-Image-Layered-GGUF
DECOMPOSER_GGUF_FILE=qwen-image-layered-Q8_0.gguf

# Runtime paths
DECOMPOSER_RUNS_DIR=runs

# Limits
DECOMPOSER_MAX_ZIP_BYTES=524288000
DECOMPOSER_INFERENCE_TIMEOUT_SECONDS=600.0
DECOMPOSER_JOB_TTL_SECONDS=3600.0

# Defaults
DECOMPOSER_DEFAULT_RESOLUTION=640
DECOMPOSER_DEFAULT_STEPS=8
DECOMPOSER_DEFAULT_LAYERS=6

# Lightning LoRA — set both repo + filename to enable step-reduced inference
# DECOMPOSER_LIGHTNING_LORA_REPO=lightx2v/Qwen-Image-Lightning
# DECOMPOSER_LIGHTNING_LORA_FILENAME=Qwen-Image-Lightning-8steps-V2.0.safetensors
# DECOMPOSER_LIGHTNING_LORA_SCALE=1.0

# Use FakeBackend instead of MpsBackend (useful for Docker/CI without MPS)
DECOMPOSER_USE_FAKE_BACKEND=false

# Secrets — leave commented in version control; set in your private .env or environment
# DECOMPOSER_HF_TOKEN=hf_yourtoken
